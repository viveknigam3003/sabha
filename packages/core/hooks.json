{
  "version": 1,
  "_sabha_owner": "sabha-core",
  "_sabha_note": "Don't hand-edit. Merge-managed by sabha-core; entries tagged with _sabha_owner=sabha-core are owned by Sabha and may be replaced on re-install. This ONE hooks set replaces the per-agent _argus_owner / _narada_owner sets — every general now records into the single ~/.local/share/sabha/telemetry stream. Commands route through ${CLAUDE_PLUGIN_ROOT}/bin/sabha-hook.mjs, which self-heals the cache's node_modules (the marketplace copies files but never runs npm install) then dispatches to the telemetry or core CLI in-process — so there is no PATH symlink and no global install.",
  "hooks": {
    "sessionStart": [
      {
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/sabha-hook.mjs\" telemetry session-start",
        "_sabha_owner": "sabha-core"
      },
      {
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/sabha-hook.mjs\" core update-check",
        "_sabha_owner": "sabha-core"
      }
    ],
    "sessionEnd": [
      {
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/sabha-hook.mjs\" telemetry session-end",
        "_sabha_owner": "sabha-core"
      }
    ],
    "preToolUse": [
      {
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/sabha-hook.mjs\" telemetry record skill.read-probe",
        "matcher": "Read",
        "_sabha_owner": "sabha-core"
      }
    ],
    "subagentStart": [
      {
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/sabha-hook.mjs\" telemetry record subagent.start",
        "_sabha_owner": "sabha-core"
      }
    ],
    "subagentStop": [
      {
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/sabha-hook.mjs\" telemetry record subagent.stop",
        "_sabha_owner": "sabha-core"
      }
    ],
    "afterMCPExecution": [
      {
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/sabha-hook.mjs\" telemetry record tool.call",
        "_sabha_owner": "sabha-core"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/sabha-hook.mjs\" telemetry record prompt.submit",
        "_sabha_owner": "sabha-core"
      }
    ]
  }
}
