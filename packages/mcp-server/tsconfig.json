{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "composite": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "paths": {
      "@sabhahq/core": ["../core/src/index.ts"],
      "@sabhahq/core/*": ["../core/src/*.ts"],
      "@sabhahq/telemetry": ["../telemetry/src/index.ts"],
      "@sabhahq/telemetry/*": ["../telemetry/src/*.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "references": [
    { "path": "../core" },
    { "path": "../telemetry" }
  ]
}
