# Sabha runtime config — copy to `.env` (repo-local dev) or to
# ~/.config/sabha/.env (per-user, picked up by installed plugins).
#
# Loaded by @sabhahq/telemetry's loadSabhaEnv() at MCP/CLI startup. Precedence:
#   real shell env  >  $SABHA_ENV_FILE  >  ~/.config/sabha/.env
#   >  $CLAUDE_PLUGIN_ROOT/.env  >  <cwd>/.env
# Only SABHA_* (plus XDG_*/HOME) keys are honoured. Real exports always win.

# ── PostHog (client-side telemetry mirror) ────────────────────────────────────
# Real, write-only project (capture) key. Until set, the bundled placeholder
# fails closed and NOTHING is sent to PostHog.
# SABHA_POSTHOG_KEY=phc_your_real_project_key
# SABHA_POSTHOG_HOST=https://us.i.posthog.com
# Set to 1 to disable the PostHog mirror entirely (local JSONL still written).
# SABHA_POSTHOG_DISABLED=0

# ── Access gate (email allowlist) ─────────────────────────────────────────────
# Static JSON of SHA-256 email hashes: { "hashes": ["<sha256-of-email>", ...] }.
# Maintain it with `pnpm allowlist add <email>` (writes ./allowlist.json), then
# commit + push it — the default points at the public sabha repo's raw copy, so
# updating access is just a commit (no release). Override only to self-host:
#   prod:  any https URL the allowlist.json is hosted at
#   local: a file:// URL or plain path to test the gate with no hosting, e.g.
#          SABHA_ALLOWLIST_URL=file://$PWD/allowlist.json   (or just ./allowlist.json)
# SABHA_ALLOWLIST_URL=https://raw.githubusercontent.com/viveknigam3003/sabha/main/allowlist.json
# Maintainer/dev escape hatch — bypass the gate locally. NEVER ship this set.
# SABHA_GATE_DISABLED=0

# ── Auto-update hint ──────────────────────────────────────────────────────────
# SABHA_MARKETPLACE_URL=https://raw.githubusercontent.com/viveknigam3003/sabha/main/.claude-plugin/marketplace.json
# Override the version the update-check compares against (normally the bundled version).
# SABHA_INSTALLED_VERSION=0.1.0

# ── Telemetry config (advanced) ───────────────────────────────────────────────
# Inline JSON override for the telemetry block (enabled/retentionDays/posthog/...).
# SABHA_TELEMETRY_CONFIG_JSON={"enabled":true,"retentionDays":90,"posthog":{"enabled":true}}
# Path to the YAML config the hook CLI reads (defaults to ~/.config/sabha/config.yaml).
# SABHA_CONFIG_FILE=

# ── Explicit env-file path (highest-priority file) ────────────────────────────
# SABHA_ENV_FILE=/absolute/path/to/.env
